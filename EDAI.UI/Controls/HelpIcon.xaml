<UserControl x:Class="EDAI.UI.Controls.HelpIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             VerticalAlignment="Center">

    <Grid>
        <!-- Trigger button: small info icon -->
        <Button x:Name="TriggerButton"
                Style="{StaticResource MaterialDesignIconButton}"
                Width="22" Height="22"
                Padding="0"
                Click="TriggerButton_Click"
                ToolTip="Click for help"
                Cursor="Hand">
            <materialDesign:PackIcon Kind="InformationOutline"
                                     Width="16" Height="16"
                                     Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Mid}" />
        </Button>

        <!-- Help popup: appears below the icon, closed by X button or click-outside -->
        <Popup x:Name="HelpPopup"
               PlacementTarget="{Binding ElementName=TriggerButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">

            <materialDesign:Card MinWidth="240" MaxWidth="340"
                                 Padding="0"
                                 materialDesign:ElevationAssist.Elevation="Dp8"
                                 Margin="4">
                <StackPanel>
                    <!-- Header bar with close button -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}"
                            Padding="10,6">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Width="20" Height="20"
                                    Padding="0"
                                    Click="CloseButton_Click"
                                    VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Close"
                                                         Width="13" Height="13"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                            </Button>
                            <TextBlock Text="Help"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- Help body text -->
                    <TextBlock x:Name="HelpTextBlock"
                               Padding="12,10,12,12"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </StackPanel>
            </materialDesign:Card>
        </Popup>
    </Grid>
</UserControl>
