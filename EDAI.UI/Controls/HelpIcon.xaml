<UserControl x:Class="EDAI.UI.Controls.HelpIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             VerticalAlignment="Center">

    <Grid>
        <!-- Trigger button: accent-coloured info icon -->
        <Button x:Name="TriggerButton"
                Style="{StaticResource MaterialDesignIconButton}"
                Width="22" Height="22"
                Padding="0"
                Click="TriggerButton_Click"
                ToolTip="Click for help"
                Cursor="Hand">
            <materialDesign:PackIcon Kind="InformationOutline"
                                     Width="16" Height="16"
                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
        </Button>

        <!--
            Plain Border instead of materialDesign:Card.
            materialDesign:Card has an implicit style that forces its own surface colour,
            which ignores the user's custom background/foreground settings.
            A plain Border with explicit DynamicResource bindings picks up both the
            theme defaults and any custom overrides set in Application Settings.
        -->
        <Popup x:Name="HelpPopup"
               PlacementTarget="{Binding ElementName=TriggerButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">

            <Border x:Name="PopupBorder"
                    Background="{DynamicResource MaterialDesign.Brush.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                    BorderThickness="1"
                    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                    MinWidth="240" MaxWidth="340"
                    Margin="4">
                <StackPanel>

                    <!-- Header row: accent icon + label + close -->
                    <DockPanel Margin="12,8">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="20" Height="20"
                                Padding="0"
                                Click="CloseButton_Click"
                                VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Close" Width="13" Height="13" />
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="14" Height="14"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0" />
                            <TextBlock Text="Help"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Separator using accent colour at low opacity -->
                    <Rectangle Height="1"
                               Fill="{DynamicResource MaterialDesign.Brush.Primary}"
                               Opacity="0.25" />

                    <!-- Body -->
                    <TextBlock x:Name="HelpTextBlock"
                               Padding="12,8,12,12"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18" />

                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
