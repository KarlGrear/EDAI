<UserControl x:Class="EDAI.UI.Controls.HsvColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf">

    <StackPanel>
        <!-- SV canvas: saturation (X) x value/brightness (Y) -->
        <Grid Height="200" Margin="0,0,0,10">
            <!-- White→HueColor gradient (left to right = saturation) -->
            <Rectangle x:Name="SatRect">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop x:Name="HueStop" Color="Red" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Transparent→Black gradient (top to bottom = value) -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="Black" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Interaction layer -->
            <Canvas x:Name="SvCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="OnSvMouseDown"
                    MouseLeftButtonUp="OnSvMouseUp"
                    MouseMove="OnSvMouseMove"
                    SizeChanged="OnSvCanvasSizeChanged">
                <!-- Crosshair thumb -->
                <Ellipse x:Name="SvThumb"
                         Width="14" Height="14"
                         IsHitTestVisible="False"
                         Stroke="White" StrokeThickness="2">
                    <Ellipse.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="Black" Opacity="0.7"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Grid>

        <!-- Hue strip -->
        <Grid Height="22" Margin="0,0,0,10">
            <Rectangle RadiusX="3" RadiusY="3">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF0000" Offset="0"/>
                        <GradientStop Color="#FFFF00" Offset="0.167"/>
                        <GradientStop Color="#00FF00" Offset="0.333"/>
                        <GradientStop Color="#00FFFF" Offset="0.5"/>
                        <GradientStop Color="#0000FF" Offset="0.667"/>
                        <GradientStop Color="#FF00FF" Offset="0.833"/>
                        <GradientStop Color="#FF0000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Canvas x:Name="HueCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHueMouseDown"
                    MouseLeftButtonUp="OnHueMouseUp"
                    MouseMove="OnHueMouseMove"
                    SizeChanged="OnHueCanvasSizeChanged">
                <!-- Hue position indicator -->
                <Rectangle x:Name="HueThumb"
                           Width="4" Height="22"
                           IsHitTestVisible="False"
                           Fill="White" Stroke="Black" StrokeThickness="1"
                           RadiusX="2" RadiusY="2">
                    <Rectangle.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.5"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Canvas>
        </Grid>

        <!-- Color preview + RGB inputs -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Color preview swatch -->
            <Border Grid.Column="0" CornerRadius="4" BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
                <Rectangle x:Name="ColorPreview" RadiusX="3" RadiusY="3"/>
            </Border>

            <!-- R input -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="R" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBox x:Name="RInput"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.TextBoxViewMargin="2 0 2 0"
                         FontSize="12" TextAlignment="Center"
                         LostFocus="OnRgbLostFocus"
                         KeyDown="OnRgbKeyDown"/>
            </StackPanel>

            <!-- G input -->
            <StackPanel Grid.Column="4">
                <TextBlock Text="G" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBox x:Name="GInput"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.TextBoxViewMargin="2 0 2 0"
                         FontSize="12" TextAlignment="Center"
                         LostFocus="OnRgbLostFocus"
                         KeyDown="OnRgbKeyDown"/>
            </StackPanel>

            <!-- B input -->
            <StackPanel Grid.Column="6">
                <TextBlock Text="B" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBox x:Name="BInput"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.TextBoxViewMargin="2 0 2 0"
                         FontSize="12" TextAlignment="Center"
                         LostFocus="OnRgbLostFocus"
                         KeyDown="OnRgbKeyDown"/>
            </StackPanel>
        </Grid>

        <!-- Hex input + eyedropper -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="HexInput"
                     Grid.Column="0"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="#RRGGBB"
                     FontFamily="Consolas" FontSize="13"
                     LostFocus="OnHexLostFocus"
                     KeyDown="OnHexKeyDown"/>

            <Button Grid.Column="2"
                    x:Name="EyedropperBtn"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    ToolTip="Pick color from screen — click eyedropper then click anywhere on screen"
                    Click="OnEyedropperClick"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Eyedropper" VerticalAlignment="Center"/>
                    <TextBlock Text=" Pick" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
