<Window x:Class="EDAI.UI.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:vm="clr-namespace:EDAI.UI.ViewModels"
        Title="Test — Elite Dangerous AI"
        Width="800" Height="640"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header + Run button -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right"
                    Content="Run Test"
                    Command="{Binding RunTestCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
            <TextBlock Text="Paste journal JSON lines (one per line):"
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Config selector -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left"
                       Text="Configuration:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       FontSize="12" Opacity="0.7" />
            <ComboBox ItemsSource="{Binding Configs}"
                      SelectedItem="{Binding SelectedConfig}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="All Configurations">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Title}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Text" Value="All Configurations (trigger-matched)" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DockPanel>

        <!-- JSON input -->
        <TextBox Grid.Row="2"
                 Text="{Binding InputJson, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="Paste raw journal JSON here..."
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12" />

        <GridSplitter Grid.Row="3" Height="8" HorizontalAlignment="Stretch" />

        <!-- Output area -->
        <DockPanel Grid.Row="4">
            <TextBlock DockPanel.Dock="Top"
                       Text="Output"
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       Margin="0,0,0,4" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding TestResponses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ResponseDisplayItem}">
                            <materialDesign:Card Margin="0,0,0,8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{Binding ConfigTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
