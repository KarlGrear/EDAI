<Window x:Class="EDAI.UI.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:vm="clr-namespace:EDAI.UI.ViewModels"
        Title="Test — Elite Dangerous AI"
        Width="900" Height="680"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <TabControl Style="{StaticResource MaterialDesignTabControl}" Margin="24">

        <!-- ═══════════════════════════════════════════════════════════════════
             Tab 1 — Pipeline Test
             ═══════════════════════════════════════════════════════════════════ -->
        <TabItem Header="Pipeline Test">
            <Grid Margin="0,16,0,0"
                  DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header + Run button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right"
                            Content="Run Test"
                            Command="{Binding RunTestCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
                    <TextBlock Text="Paste journal JSON lines (one per line):"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Config selector -->
                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Configuration:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="12" Opacity="0.7" />
                    <ComboBox ItemsSource="{Binding Configs}"
                              SelectedItem="{Binding SelectedConfig}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="All Configurations">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Title}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="All Configurations (trigger-matched)" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </DockPanel>

                <!-- JSON input -->
                <TextBox Grid.Row="2"
                         Text="{Binding InputJson, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Paste raw journal JSON here..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12" />

                <GridSplitter Grid.Row="3" Height="8" HorizontalAlignment="Stretch" />

                <!-- Output area -->
                <DockPanel Grid.Row="4">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Output"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,4" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TestResponses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ResponseDisplayItem}">
                                    <materialDesign:Card Margin="0,0,0,8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ConfigTitle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                       Margin="0,0,0,4"
                                                       Visibility="{Binding ShowTitle, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════════════════
             Tab 2 — Template Tester
             ═══════════════════════════════════════════════════════════════════ -->
        <TabItem Header="Template Tester">
            <DockPanel Margin="0,16,0,0" LastChildFill="True"
                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                       x:Name="TemplateTesterPanel">

                <!-- Aux file hint -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding AuxIdentifiersHint}"
                           FontSize="11"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Opacity="0.8"
                           Margin="0,0,0,8" />

                <!-- Side-by-side JSON inputs (fixed height) -->
                <Grid DockPanel.Dock="Top" Height="180" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Trigger JSON"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding TemplateTriggerJson, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Paste trigger event JSON here"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12" />
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" />

                    <DockPanel Grid.Column="2">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Result JSON"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding TemplateResultJson, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Paste AI result JSON here"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12" />
                    </DockPanel>
                </Grid>

                <!-- Template label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Template"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Margin="0,12,0,4" />

                <!-- Template input -->
                <TextBox DockPanel.Dock="Top"
                         Height="70"
                         Text="{Binding TemplateInput, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="e.g. Arrived in |trigger.StarSystem| — threat: |result.threat_level| — fuel: |status.Fuel.FuelMain|"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12" />

                <!-- Condition label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Condition (optional)"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Margin="0,12,0,4" />

                <!-- Condition input + result badge -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,0">
                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               MinWidth="48"
                               Text="{Binding TemplateConditionResult}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TemplateConditionResult}" Value="True">
                                        <Setter Property="Foreground" Value="#FF4CAF50" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TemplateConditionResult}" Value="False">
                                        <Setter Property="Foreground" Value="#FFEE3333" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TemplateConditionResult}" Value="Error">
                                        <Setter Property="Foreground" Value="#FFEE3333" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding TemplateCondition, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint='e.g.  |trigger.SystemAllegiance| == "Independent"'
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </DockPanel>

                <!-- Run button + status -->
                <DockPanel DockPanel.Dock="Top" Margin="0,8,0,4">
                    <Button DockPanel.Dock="Left"
                            Content="Run Test"
                            Command="{Binding EvaluateTemplateCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,12,0" />
                    <TextBlock Text="{Binding TemplateStatus}"
                               FontSize="11"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Output label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Output"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Margin="0,0,0,4" />

                <!-- Output — fills remaining space -->
                <TextBox Text="{Binding TemplateOutput, Mode=OneWay}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13" />

            </DockPanel>
        </TabItem>

    </TabControl>
</Window>
