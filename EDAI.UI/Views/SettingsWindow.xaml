<Window x:Class="EDAI.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:controls="clr-namespace:EDAI.UI.Controls"
        Title="Application Settings — Elite Dangerous AI"
        Width="560" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel Margin="24">

        <!-- Save / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource EDAI.Button.Primary}"
                    IsDefault="True" Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>

        <TabControl>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- GENERAL                                                        -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,0">
                    <StackPanel Margin="0,14,0,0">

                        <!-- Minimize to System Tray -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="When enabled, clicking the window close button (✕) minimises EDAI to the system tray instead of exiting. Right-click the tray icon to restore or exit. Hold Shift while clicking ✕ to always exit immediately regardless of this setting." />
                            <CheckBox Content="Minimize to System Tray on Close"
                                      IsChecked="{Binding MinimizeToTray}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Always on top -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="When enabled, the EDAI window floats in front of all other applications — useful while playing Elite Dangerous full-screen (windowed mode). Can also be toggled from the main window toolbar." />
                            <CheckBox Content="Always on Top"
                                      IsChecked="{Binding AlwaysOnTop}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Show splash screen -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="When enabled, the EDAI splash screen is shown for 5 seconds each time the application starts." />
                            <CheckBox Content="Show Splash Screen on Launch"
                                      IsChecked="{Binding ShowSplashScreen}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Tray notifications -->
                        <DockPanel Margin="0,0,0,24">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Global override for tray notifications. When disabled, no balloon notifications are shown regardless of per-configuration settings. When enabled, each configuration's own 'Show Tray Notification' checkbox controls whether it notifies." />
                            <CheckBox Content="Tray Notifications Enabled"
                                      IsChecked="{Binding TrayNotificationsEnabled}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Journal -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Full path to the folder containing Elite Dangerous Journal files (Journal.YYYY-MM-DDTHHMMSS.NN.log). Change this only if you have moved the game's save folder or are using a non-standard installation." />
                            <TextBlock Text="Journal Folder" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="Browse…"
                                    Command="{Binding BrowseJournalPathCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="8,0,0,0" />
                            <TextBox materialDesign:HintAssist.Hint="Journal folder path"
                                     Text="{Binding JournalPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EDAI.Form.TextBox}" />
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- AI                                                             -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,0">
                    <StackPanel Margin="0,14,0,0">

                        <!-- API Key -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Your secret OpenAI API key from platform.openai.com. Stored encrypted on this PC using Windows DPAPI — never written in plain text. Never shared or transmitted except in direct API calls to OpenAI." />
                            <TextBlock Text="API Key" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBox materialDesign:HintAssist.Hint="Paste your OpenAI API key here"
                                 Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EDAI.Form.TextBox}"
                                 Margin="0,0,0,12" />

                        <!-- Model -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="The OpenAI model used to process your events. GPT-4o gives the richest, most accurate responses. GPT-4o-mini is faster and cheaper. Type any valid model ID to use an unlisted model." />
                            <TextBlock Text="Model" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <ComboBox materialDesign:HintAssist.Hint="Model"
                                  ItemsSource="{Binding OpenAiModels}"
                                  SelectedItem="{Binding OpenAiModel}"
                                  IsEditable="True"
                                  Style="{StaticResource EDAI.Form.ComboBox}"
                                  Margin="0,0,0,16" />

                        <!-- System Persona -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="The system message sent to the AI before every prompt. Sets the AI's persona and behaviour. Use 'Reset to Default' to restore the original EDAI persona." />
                            <TextBlock Text="System Persona" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBox Text="{Binding SystemPersona, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EDAI.Form.TextBox}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 materialDesign:HintAssist.Hint="System persona sent to the AI"
                                 Margin="0,0,0,4" />
                        <Button Content="Reset to Default"
                                Command="{Binding ResetSystemPersonaCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- TTS                                                            -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="TTS">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,0">
                    <StackPanel Margin="0,14,0,0">

                        <!-- TTS Enabled -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Master on/off switch for all speech announcements. You can also toggle TTS from the main window toolbar (the speaker icon) without changing this setting." />
                            <CheckBox Content="TTS Enabled"
                                      IsChecked="{Binding TtsEnabled}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Voice Engine -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Windows Speech (SAPI): uses voices installed on your PC — offline, no latency. Edge Neural Voices: uses Microsoft's cloud neural engine via the same backend as Edge Read Aloud — requires internet, ~300 ms startup per utterance, no account or API key needed." />
                            <TextBlock Text="Voice Engine" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <ComboBox materialDesign:HintAssist.Hint="Voice Engine"
                                  ItemsSource="{Binding TtsEngines}"
                                  SelectedItem="{Binding SelectedTtsEngine}"
                                  Style="{StaticResource EDAI.Form.ComboBox}"
                                  Margin="0,0,0,16" />

                        <!-- SAPI panel -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSapiEngine}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="The Windows SAPI voice used for speech. Only voices installed on your system appear here. Additional voices can be installed via Windows Settings → Time &amp; Language → Speech. Click 'Test Voice' to hear a sample before saving." />
                                <TextBlock Text="Voice" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right"
                                        Content="Test Voice"
                                        Command="{Binding TestVoiceCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="8,0,0,0" />
                                <ComboBox materialDesign:HintAssist.Hint="TTS Voice"
                                          ItemsSource="{Binding TtsVoices}"
                                          SelectedItem="{Binding SelectedTtsVoice}"
                                          Style="{StaticResource EDAI.Form.ComboBox}" />
                            </DockPanel>
                        </StackPanel>

                        <!-- Edge Neural panel -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEdgeEngine}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Language -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="Filter the voice list to a specific English accent. English (United States) includes ~20 voices; English (United Kingdom) includes 5 voices." />
                                <TextBlock Text="Language" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                            </DockPanel>
                            <ComboBox materialDesign:HintAssist.Hint="Language"
                                      ItemsSource="{Binding EdgeLanguages}"
                                      SelectedItem="{Binding SelectedEdgeLanguage}"
                                      DisplayMemberPath="Display"
                                      Style="{StaticResource EDAI.Form.ComboBox}"
                                      Margin="0,0,0,12" />

                            <!-- Rate -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="Speech rate multiplier. 1.0 is normal speed. 0.5 is half speed, 2.0 is double speed." />
                                <TextBlock Text="Rate" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock DockPanel.Dock="Right" Width="40" TextAlignment="Right"
                                           Text="{Binding EdgeTtsRate, StringFormat={}{0:F1}x}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                <Slider Value="{Binding EdgeTtsRate}"
                                        Minimum="0.5" Maximum="2.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <!-- Pitch -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="Speech pitch multiplier. 1.0 is the voice's natural pitch. Values above 1.0 raise the pitch; values below 1.0 lower it." />
                                <TextBlock Text="Pitch" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock DockPanel.Dock="Right" Width="40" TextAlignment="Right"
                                           Text="{Binding EdgeTtsPitch, StringFormat={}{0:F1}x}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                <Slider Value="{Binding EdgeTtsPitch}"
                                        Minimum="0.5" Maximum="2.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <!-- Voice -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="The Edge Neural voice to use. Voices are listed as 'Name (Gender)'. Click 'Test Voice' to hear a sample." />
                                <TextBlock Text="Voice" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,16">
                                <Button DockPanel.Dock="Right"
                                        Content="Test Voice"
                                        Command="{Binding TestVoiceCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="8,0,0,0" />
                                <ComboBox materialDesign:HintAssist.Hint="Edge Neural Voice"
                                          ItemsSource="{Binding FilteredEdgeVoices}"
                                          SelectedItem="{Binding SelectedEdgeVoice}"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource EDAI.Form.ComboBox}" />
                            </DockPanel>

                            <!-- Clear Voice Cache -->
                            <DockPanel Margin="0,0,0,8">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="Permanently deletes all cached Edge Neural audio files and their database records. Useful for freeing disk space or forcing a fresh API fetch." />
                                <Button Content="Clear Voice Cache"
                                        Command="{Binding ClearVoiceCacheCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        HorizontalAlignment="Left" />
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- THEME                                                          -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="Theme">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,0">
                    <StackPanel Margin="0,14,0,0">

                        <!-- Colors -->
                        <TextBlock Text="Colors"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,16"
                                   Text="Customize the base theme, accent color, toolbar, buttons, and form control colors. Changes take effect immediately." />
                        <Button Content="Change Colors…"
                                Command="{Binding OpenThemeCommand}"
                                Style="{StaticResource EDAI.Button.Primary}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,24" />

                        <Separator Margin="0,0,0,20" />

                        <!-- Font Family -->
                        <TextBlock Text="Font"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,12" />
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="The font used throughout the interface. Leave blank for the default Material Design font." />
                            <TextBlock Text="Font Family" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <ComboBox materialDesign:HintAssist.Hint="Font (blank = default)"
                                  ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding SelectedFontFamily}"
                                  IsEditable="True"
                                  Style="{StaticResource EDAI.Form.ComboBox}"
                                  Margin="0,0,0,12" />

                        <!-- Font Size -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Base font size in points. Default is 14. Scales all text in the interface." />
                            <TextBlock Text="Font Size" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Right" Width="40" TextAlignment="Right"
                                       Text="{Binding FontSize, StringFormat={}{0:F0} pt}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                            <Slider Value="{Binding FontSize}"
                                    Minimum="8" Maximum="32"
                                    TickFrequency="1" IsSnapToTickEnabled="True" />
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- SCRIPTING                                                       -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TabItem Header="Scripting">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,0">
                    <StackPanel Margin="0,14,0,0">

                        <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,16"
                                   Text="C# process scripts can run arbitrary code on your machine. These permissions are off by default. Only enable capabilities required by scripts you trust. Imported scripts that use capabilities not enabled here will fail to run." />

                        <!-- File System -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Grants scripts access to System.IO — reading and writing files and directories. Required for scripts that read game data files beyond the built-in journal/aux file variables." />
                            <CheckBox Content="Allow File System Access (System.IO)"
                                      IsChecked="{Binding ScriptingAllowFileSystem}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Network -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Grants scripts access to System.Net.Http — making HTTP requests. Required for scripts that call external web services or APIs." />
                            <CheckBox Content="Allow Network Access (System.Net.Http)"
                                      IsChecked="{Binding ScriptingAllowNetwork}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Process Execution -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Grants scripts access to System.Diagnostics — launching external processes. Required for scripts that need to run other programs or shell commands." />
                            <CheckBox Content="Allow Process Execution (System.Diagnostics)"
                                      IsChecked="{Binding ScriptingAllowProcessExecution}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <!-- Reflection -->
                        <DockPanel Margin="0,0,0,12">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Grants scripts access to System.Reflection — inspecting and invoking types dynamically. Required for advanced meta-programming scenarios. Use with caution." />
                            <CheckBox Content="Allow Reflection (System.Reflection)"
                                      IsChecked="{Binding ScriptingAllowReflection}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <Separator Margin="0,8,0,16" />

                        <!-- Session -->
                        <TextBlock Text="Session"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,8">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Session variables are shared across all pipelines and persisted in session.json next to the executable. Scripts read them via Session[&quot;key&quot;] and write via SetSession / DeleteSession / ClearSession. Templates use |session.key| tokens. Clearing resets all values to an empty object." />
                            <Button Content="Clear Session"
                                    Command="{Binding ClearSessionCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    HorizontalAlignment="Left" />
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
