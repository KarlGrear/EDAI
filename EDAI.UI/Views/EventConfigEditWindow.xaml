<Window x:Class="EDAI.UI.Views.EventConfigEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:controls="clr-namespace:EDAI.UI.Controls"
        Title="Event Settings — Elite Dangerous AI"
        Width="860" Height="700"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>

        <!-- ── Bottom action bar ──────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                Padding="24,12">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Delete"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#FFEE3333"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ValidationError}"
                               Foreground="#FFEE3333"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationError}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource EDAI.Button.Primary}"
                            IsDefault="True"
                            Margin="0,0,8,0" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Phase tabs ─────────────────────────────────────────── -->
        <TabControl Style="{StaticResource MaterialDesignTabControl}">

            <!-- ══ GENERAL ══════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="General" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" MaxWidth="560" HorizontalAlignment="Left">

                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Required. A short descriptive name for this configuration. Shown in the AI response panel and any tray notifications when this event fires." />
                            <TextBlock Text="Title" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <TextBox materialDesign:HintAssist.Hint="Title *"
                                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EDAI.Form.TextBox}"
                                 Margin="0,0,0,16" />

                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Optional internal notes. Not shown during normal operation — purely for your own reference when browsing configurations." />
                            <TextBlock Text="Description" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <TextBox materialDesign:HintAssist.Hint="Description (optional)"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EDAI.Form.TextBox}"
                                 Margin="0,0,0,16" />

                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Organise configurations into named groups. Categories appear as a filter on the selection screen. Use 'Manage' to create or rename categories." />
                            <TextBlock Text="Category" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      materialDesign:HintAssist.Hint="Category (optional)"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      Style="{StaticResource EDAI.Form.ComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="2"
                                    Content="Manage"
                                    Command="{Binding ManageCategoriesCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </Grid>

                        <DockPanel Margin="0,0,0,20">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="When unchecked, this configuration is completely inactive — no AI calls are made even when matching events are received. You can also toggle this from the selection screen." />
                            <CheckBox Content="Enabled"
                                      IsChecked="{Binding IsEnabled}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Override the AI model for this configuration only. Leave empty to use the model configured in Application Settings. Example: gpt-4o-mini" />
                            <TextBlock Text="Model Override" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <ComboBox materialDesign:HintAssist.Hint="Leave empty to use Application Settings model"
                                  ItemsSource="{Binding OpenAiModels}"
                                  Text="{Binding ModelOverride, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Style="{StaticResource EDAI.Form.ComboBox}" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ TRIGGER ══════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LightningBolt" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Trigger" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Trigger Cooldown -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Minimum time that must pass before this event can fire again. Set to 0 to disable the cooldown. Use this to prevent repeated triggers when travelling between the same systems, or to limit AI token usage on noisy events." />
                            <TextBlock Text="Trigger Cooldown (optional)" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="0 = off"
                                     Text="{Binding TriggerTimeoutValue, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EDAI.Form.TextBox}" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding TriggerTimeoutUnits}"
                                      SelectedItem="{Binding TriggerTimeoutUnit}"
                                      Style="{StaticResource EDAI.Form.ComboBox}" />
                        </Grid>

                        <!-- Triggering Events -->
                        <DockPanel Margin="0,0,0,8">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="The Elite Dangerous journal event types that activate this pipeline. If any one of the listed types is received (OR logic), the full pipeline runs. Common examples: FSDJump, Docked, ScanDetailed, MissionCompleted." />
                            <TextBlock Text="Triggering Events"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding TriggeringEvents}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Padding="10,3,2,3"
                                            Margin="0,2,6,2">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                                            <Button Command="{Binding DataContext.RemoveTriggeringEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                                    Width="20" Height="20" Padding="2">
                                                <materialDesign:PackIcon Kind="Close" Width="10" Height="10" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Add event type (e.g. FSDJump)"
                                     Text="{Binding NewTriggeringEvent, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EDAI.Form.TextBox}" />
                            <Button Grid.Column="2"
                                    Content="Add"
                                    Command="{Binding AddTriggeringEventCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </Grid>

                        <!-- Trigger Condition -->
                        <DockPanel Margin="0,0,0,4">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Optional condition that must be true for this pipeline to fire. Leave blank to always fire. Supports token replacement and comparison operators: == != &gt; &lt; &gt;= &lt;=&#x0a;&#x0a;Examples:&#x0a;  |trigger.SystemAllegiance| == &quot;Independent&quot;&#x0a;  |trigger.Population| &gt; 1000000" />
                            <TextBlock Text="Trigger Condition (optional)" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <controls:ScriptEditor Text="{Binding TriggerCondition}"
                                              CompletionTokens="{Binding ResultTokenList}"
                                              IsReadOnly="{Binding HasTriggerConditionScript}"
                                              MinHeight="30"
                                              Margin="0,0,0,4">
                            <controls:ScriptEditor.Style>
                                <Style TargetType="{x:Type controls:ScriptEditor}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTriggerConditionScript}" Value="True">
                                            <Setter Property="Opacity" Value="0.45" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:ScriptEditor.Style>
                        </controls:ScriptEditor>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="C# script: none" />
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasTriggerConditionScript}" Value="True">
                                                <Setter Property="Text" Value="C# script: configured (overrides text condition)" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="2"
                                    Content="Script..."
                                    Command="{Binding EditTriggerConditionScriptCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                            <Button Grid.Column="4"
                                    Content="Clear"
                                    Command="{Binding ClearTriggerConditionScriptCommand}"
                                    IsEnabled="{Binding HasTriggerConditionScript}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </Grid>

                        <!-- Secondary Events -->
                        <StackPanel IsEnabled="{Binding IsSecondaryEventsEnabled}" Margin="0,24,0,0">
                            <DockPanel Margin="0,0,0,8">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="Optional events to collect after the trigger fires. EDAI waits up to the configured milliseconds gathering any matching events, then includes them all in the AI prompt for richer context." />
                                <TextBlock Text="Secondary Events"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding SecondaryEvents}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Padding="10,3,2,3"
                                                Margin="0,2,6,2">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                                                <Button Command="{Binding DataContext.RemoveSecondaryEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                                        Width="20" Height="20" Padding="2">
                                                    <materialDesign:PackIcon Kind="Close" Width="10" Height="10" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         materialDesign:HintAssist.Hint="Add secondary event type"
                                         Text="{Binding NewSecondaryEvent, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EDAI.Form.TextBox}" />
                                <Button Grid.Column="2"
                                        Content="Add"
                                        Command="{Binding AddSecondaryEventCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                            </Grid>

                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="How many milliseconds to wait after the trigger fires before building the AI prompt. During this window, matching secondary events are collected. Set to 0 to skip secondary event collection." />
                                <TextBlock Text="Secondary Wait (ms)" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </DockPanel>
                            <TextBox materialDesign:HintAssist.Hint="Milliseconds to wait (e.g. 1000)"
                                     Text="{Binding SecondaryWaitTimeMs, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EDAI.Form.TextBox}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ PROCESSING ════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Processing" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Processing Mode -->
                        <DockPanel Margin="0,0,0,8">
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="None: event is detected but no processing occurs. AI: sends a prompt to OpenAI and uses the response for display and announcements. Script: runs a custom C# script to produce the output." />
                            <TextBlock Text="Processing Mode"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <RadioButton Content="None"
                                         IsChecked="{Binding ProcessingType, Converter={StaticResource EnumToBool}, ConverterParameter=None}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="AI"
                                         IsChecked="{Binding ProcessingType, Converter={StaticResource EnumToBool}, ConverterParameter=Ai}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="Script"
                                         IsChecked="{Binding ProcessingType, Converter={StaticResource EnumToBool}, ConverterParameter=Script}"
                                         Style="{StaticResource MaterialDesignRadioButton}" />
                        </StackPanel>

                        <!-- AI section -->
                        <StackPanel Visibility="{Binding IsAiMode, Converter={StaticResource BoolToVis}}">

                            <!-- Prompt -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="The instruction sent to OpenAI. Use |trigger.fieldName| tokens to embed specific trigger values. Example: 'Analyse the system |trigger.StarSystem| and assess threats.'" />
                                <TextBlock Text="Prompt"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </DockPanel>
                            <controls:ScriptEditor Text="{Binding Prompt}"
                                                  CompletionTokens="{Binding ResultTokenList}"
                                                  MinHeight="80" MaxHeight="200"
                                                  Margin="0,0,0,20" />

                            <!-- Expected Results Schema -->
                            <DockPanel Margin="0,0,0,4">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText='A JSON template defining the structure of the AI response. Example: {"system_name": "", "threat_level": "", "recommendation": ""}&#x0a;&#x0a;Keys defined here become available as |result.key| tokens on the Action tab.' />
                                <TextBlock Text="Expected Results Schema (JSON)"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </DockPanel>
                            <TextBox materialDesign:HintAssist.Hint="Paste JSON schema here"
                                     Text="{Binding ExpectedResultsSchema, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}"
                                     Style="{StaticResource EDAI.Form.TextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="60" MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     Margin="0,0,0,8" />

                            <!-- Available tokens -->
                            <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                    CornerRadius="4"
                                    Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="Available Tokens" FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding AvailableTokens}"
                                               FontSize="11" FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               Opacity="0.85" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- Script section -->
                        <StackPanel Visibility="{Binding IsScriptMode, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,8">
                                <controls:HelpIcon DockPanel.Dock="Right"
                                                   HelpText="A C# script that runs when this event fires and returns a result object. Use globals.Trigger and globals.Secondary to access event data. The script result is used as-is for display and announcements." />
                                <TextBlock Text="Process Script"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProcessScriptSummary}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <Button Grid.Column="2"
                                        Content="Edit Script..."
                                        Command="{Binding EditProcessScriptCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button Grid.Column="4"
                                        Content="Clear"
                                        Command="{Binding ClearProcessScriptCommand}"
                                        IsEnabled="{Binding HasProcessScript}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ ACTION ════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Bullhorn" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Action" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Display | Announce side by side -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ── Display ─────────────────────────── -->
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="16">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <controls:HelpIcon DockPanel.Dock="Right"
                                                           HelpText="Controls what appears in the EDAI response panel when this event fires. Use |fieldname| tokens in each line to insert AI response values." />
                                        <TextBlock Text="Display"
                                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,12">
                                        <controls:HelpIcon DockPanel.Dock="Right"
                                                           HelpText="When checked, the configuration title is shown as a heading above the response in the EDAI display panel." />
                                        <CheckBox Content="Show Title"
                                                  IsChecked="{Binding DisplayTitle}"
                                                  Style="{StaticResource EDAI.Form.CheckBox}" />
                                    </DockPanel>

                                    <TextBlock Text="Display Lines" FontSize="12" Margin="0,0,0,4"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />

                                    <ItemsControl ItemsSource="{Binding DisplayFields}" Margin="0,0,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                                        CornerRadius="4"
                                                        Padding="8,4"
                                                        Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding}"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Consolas" FontSize="11"
                                                                   TextWrapping="Wrap" />
                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.RemoveDisplayFieldCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="24" Height="24">
                                                            <materialDesign:PackIcon Kind="Close" Width="12" Height="12" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <controls:ScriptEditor Grid.Column="0"
                                                           Text="{Binding NewDisplayField}"
                                                           CompletionTokens="{Binding ResultTokenList}"
                                                           MinHeight="30" />
                                        <Button Grid.Column="2"
                                                Content="Add"
                                                Command="{Binding AddDisplayFieldCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </Grid>

                                    <TextBlock Text="Display Condition (optional)" FontSize="12" Margin="0,0,0,4"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                    <controls:ScriptEditor Text="{Binding DisplayCondition}"
                                                          CompletionTokens="{Binding ResultTokenList}"
                                                          MinHeight="30"
                                                          Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Script: none" />
                                                    <Setter Property="Opacity" Value="0.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDisplayConditionScript}" Value="True">
                                                            <Setter Property="Text" Value="Script: configured" />
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2"
                                                Content="Script..."
                                                Command="{Binding EditDisplayConditionScriptCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="8,4" FontSize="11" />
                                        <Button Grid.Column="4"
                                                Content="Clear"
                                                Command="{Binding ClearDisplayConditionScriptCommand}"
                                                IsEnabled="{Binding HasDisplayConditionScript}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="8,4" FontSize="11" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ── Announce ────────────────────────── -->
                            <Border Grid.Column="2"
                                    BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="16">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <controls:HelpIcon DockPanel.Dock="Right"
                                                           HelpText="Controls what EDAI speaks aloud when this event fires. Use |fieldname| tokens in each line to insert AI response values. Requires TTS enabled in Application Settings." />
                                        <TextBlock Text="Announce (TTS)"
                                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,12">
                                        <controls:HelpIcon DockPanel.Dock="Right"
                                                           HelpText="When checked, the configuration title is spoken aloud before the announcement text." />
                                        <CheckBox Content="Speak Title"
                                                  IsChecked="{Binding AnnounceTitle}"
                                                  Style="{StaticResource EDAI.Form.CheckBox}" />
                                    </DockPanel>

                                    <TextBlock Text="Announce Lines" FontSize="12" Margin="0,0,0,4"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />

                                    <ItemsControl ItemsSource="{Binding AnnounceFields}" Margin="0,0,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                                        CornerRadius="4"
                                                        Padding="8,4"
                                                        Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding}"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Consolas" FontSize="11"
                                                                   TextWrapping="Wrap" />
                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.RemoveAnnounceFieldCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="24" Height="24">
                                                            <materialDesign:PackIcon Kind="Close" Width="12" Height="12" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <controls:ScriptEditor Grid.Column="0"
                                                           Text="{Binding NewAnnounceField}"
                                                           CompletionTokens="{Binding ResultTokenList}"
                                                           MinHeight="30" />
                                        <Button Grid.Column="2"
                                                Content="Add"
                                                Command="{Binding AddAnnounceFieldCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </Grid>

                                    <TextBlock Text="Announce Condition (optional)" FontSize="12" Margin="0,0,0,4"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                    <controls:ScriptEditor Text="{Binding AnnounceCondition}"
                                                          CompletionTokens="{Binding ResultTokenList}"
                                                          MinHeight="30"
                                                          Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Script: none" />
                                                    <Setter Property="Opacity" Value="0.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAnnounceConditionScript}" Value="True">
                                                            <Setter Property="Text" Value="Script: configured" />
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2"
                                                Content="Script..."
                                                Command="{Binding EditAnnounceConditionScriptCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="8,4" FontSize="11" />
                                        <Button Grid.Column="4"
                                                Content="Clear"
                                                Command="{Binding ClearAnnounceConditionScriptCommand}"
                                                IsEnabled="{Binding HasAnnounceConditionScript}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="8,4" FontSize="11" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Tray Notification -->
                        <DockPanel>
                            <controls:HelpIcon DockPanel.Dock="Right"
                                               HelpText="Show a Windows tray balloon notification when this configuration fires and the app is minimised. The global 'Tray Notifications Enabled' toggle in Settings must also be on." />
                            <CheckBox Content="Show Tray Notification"
                                      IsChecked="{Binding ShowTrayNotification}"
                                      Style="{StaticResource EDAI.Form.CheckBox}" />
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
