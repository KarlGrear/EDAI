<Window x:Class="EDAI.UI.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:vm="clr-namespace:EDAI.UI.ViewModels"
        Title="History — Elite Dangerous AI"
        Width="700" Height="640"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top"
                   Text="Response History"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,12" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HistoryItem}">
                        <Expander IsExpanded="{Binding IsExpanded}"
                                  HorizontalContentAlignment="Stretch"
                                  Margin="0,0,0,4">
                            <Expander.Header>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TimestampDisplay}"
                                               FontSize="10" Opacity="0.6"
                                               VerticalAlignment="Top"
                                               Margin="0,2,10,0"
                                               FontFamily="Consolas" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding ConfigTitle}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Summary}"
                                                   FontSize="11" Opacity="0.75"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>

                            <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                    CornerRadius="4" Padding="12" Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="Prompt"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding PromptSent, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas" FontSize="11"
                                             MaxHeight="180"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Margin="0,0,0,12" />
                                    <TextBlock Text="AI Response"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding RawAiResponse, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas" FontSize="11"
                                             MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="Transparent"
                                             BorderThickness="0" />
                                </StackPanel>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
