<Window x:Class="EDAI.UI.Views.ScriptDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="{Binding WindowTitle}"
        Width="960" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel Margin="12">

        <!-- Bottom action bar -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Validate"
                    Command="{Binding ValidateCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />

            <!-- Validation output -->
            <ScrollViewer Grid.Column="1" Margin="12,0" VerticalScrollBarVisibility="Auto" MaxHeight="48">
                <TextBlock Text="{Binding ValidationOutput}"
                           TextWrapping="Wrap"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasValidationErrors}" Value="True">
                                    <Setter Property="Foreground" Value="#F44336" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                    <Setter Property="Foreground" Value="#4CAF50" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </ScrollViewer>

            <Button Grid.Column="2" x:Name="OkButton"
                    Content="{Binding OkButtonLabel}"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Style="{StaticResource EDAI.Button.Primary}"
                    Margin="0,0,8,0" />
            <Button Grid.Column="3"
                    Content="Cancel"
                    IsCancel="True"
                    Visibility="{Binding IsNotStandalone, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
        </Grid>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- Left: Editor + Test section -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="200" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Script editor (populated from code-behind) -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource EDAI.Brush.ControlBorder}"
                        BorderThickness="1">
                    <avalonEdit:TextEditor x:Name="ScriptEditor"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="13"
                                           ShowLineNumbers="True"
                                           WordWrap="False"
                                           Background="{DynamicResource MaterialDesign.Brush.Background}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
                        <avalonEdit:TextEditor.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Undo" Command="ApplicationCommands.Undo" />
                                <MenuItem Header="Redo" Command="ApplicationCommands.Redo" />
                                <Separator />
                                <MenuItem Header="Cut" Command="ApplicationCommands.Cut" />
                                <MenuItem Header="Copy" Command="ApplicationCommands.Copy" />
                                <MenuItem Header="Paste" Command="ApplicationCommands.Paste" />
                                <Separator />
                                <MenuItem Header="Select All" Command="ApplicationCommands.SelectAll" />
                            </ContextMenu>
                        </avalonEdit:TextEditor.ContextMenu>
                    </avalonEdit:TextEditor>
                </Border>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5" />

                <!-- Test section -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" MinHeight="60" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" MinHeight="60" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right"
                                Content="Run Test"
                                Command="{Binding TestRunCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                IsEnabled="{Binding IsTestRunning, Converter={StaticResource InverseBoolConverter}}"
                                Margin="8,0,0,0" />
                        <TextBlock Text="Test Trigger JSON" FontSize="11" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding TestTriggerJson, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource EDAI.Form.TextBox}"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="12"
                             AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />

                    <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Height="5" />

                    <!-- Output — label docked inside the star row so the splitter only sees two star rows -->
                    <DockPanel Grid.Row="3">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Output" FontSize="11" Opacity="0.7" Margin="0,2,0,2" />
                        <TextBox Text="{Binding TestOutput, Mode=OneWay}"
                                 IsReadOnly="True"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="12"
                                 Padding="6"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                 Background="{DynamicResource MaterialDesign.Brush.Background}"
                                 BorderBrush="{DynamicResource EDAI.Brush.ControlBorder}"
                                 BorderThickness="1"
                                 CaretBrush="{DynamicResource MaterialDesign.Brush.Foreground}">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Padding="{TemplateBinding Padding}" />
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                    </DockPanel>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" VerticalAlignment="Stretch"
                          HorizontalAlignment="Center" Width="5"
                          ResizeDirection="Columns" />

            <!-- Right: Globals reference -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Globals Reference"
                           FontSize="12" Opacity="0.7"
                           Margin="4,0,0,6" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding GlobalsReference}"
                               FontFamily="Consolas,Courier New,monospace"
                               FontSize="11"
                               TextWrapping="NoWrap"
                               Margin="4,0" />
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
