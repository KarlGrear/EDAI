<Window x:Class="EDAI.UI.Views.ThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:controls="clr-namespace:EDAI.UI.Controls"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Theme Customization"
        Width="900" Height="640"
        MinWidth="780" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*" MinWidth="340"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Controls ══════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0">

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0"/>
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource EDAI.Button.Primary}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top"
                       Text="Theme Customization"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,16"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Element to customize"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Elements}"
                          SelectedItem="{Binding SelectedElement}"
                          Style="{StaticResource EDAI.Form.ComboBox}"
                          materialDesign:HintAssist.Hint="Select element"/>
            </StackPanel>

            <Button DockPanel.Dock="Top"
                    Content="Reset to Default"
                    Command="{Binding ResetElementCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16"/>

            <controls:HsvColorPicker SelectedColor="{Binding CurrentColor, Mode=TwoWay}"/>
        </DockPanel>

        <!-- ══ DIVIDER ═════════════════════════════════════════════════════════ -->
        <Rectangle Grid.Column="1" Width="1"
                   Fill="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                   VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

        <!-- ══ RIGHT: Tabbed preview ══════════════════════════════════════════ -->
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top"
                       Text="Live Preview"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,12"/>

            <TabControl SelectedIndex="{Binding PreviewTabIndex, Mode=OneWay}"
                        Style="{StaticResource MaterialDesignTabControl}">

                <!-- ── App Preview tab ──────────────────────────────────────── -->
                <TabItem Header="App">
                    <Border BorderThickness="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                            CornerRadius="0,4,4,4" ClipToBounds="True">
                        <DockPanel>
                            <ToolBarTray DockPanel.Dock="Top"
                                         Background="{DynamicResource EDAI.Brush.ToolbarBackground}">
                                <ToolBar Style="{DynamicResource MaterialDesignToolBar}"
                                         Background="{DynamicResource EDAI.Brush.ToolbarBackground}"
                                         ClipToBounds="False">
                                    <TextBlock Text="ELITE DANGEROUS AI"
                                               FontWeight="Bold" FontSize="12"
                                               VerticalAlignment="Center" Margin="4,0,12,0"
                                               Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}"/>
                                    <Separator/>
                                    <Button Style="{StaticResource MaterialDesignToolButton}"
                                            Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                                        <materialDesign:PackIcon Kind="Cog"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignToolButton}"
                                            Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                                        <materialDesign:PackIcon Kind="ListBox"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignToolButton}"
                                            Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                                        <materialDesign:PackIcon Kind="Palette"/>
                                    </Button>
                                </ToolBar>
                            </ToolBarTray>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16"
                                            Background="{DynamicResource MaterialDesign.Brush.Background}">
                                    <TextBlock Text="Sample AI Response"
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                               Margin="0,0,0,8"/>
                                    <materialDesign:Card Margin="0,0,0,12" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Jump Complete — Shinrarta Dezhra"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Threat level: Low. No combat zones detected. Station Jameson Memorial is 0.24 ls from entry."
                                                       TextWrapping="Wrap" FontSize="12"/>
                                            <TextBlock Text="14:32:05" FontSize="10" Opacity="0.5"
                                                       HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <TextBlock Text="Sample Controls"
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                               Margin="0,4,0,8"/>
                                    <ComboBox Margin="0,0,0,8"
                                              Style="{StaticResource EDAI.Form.ComboBox}"
                                              materialDesign:HintAssist.Hint="Sample dropdown">
                                        <ComboBoxItem Content="Option One" IsSelected="True"/>
                                        <ComboBoxItem Content="Option Two"/>
                                    </ComboBox>
                                    <TextBox Margin="0,0,0,8"
                                             Style="{StaticResource EDAI.Form.TextBox}"
                                             materialDesign:HintAssist.Hint="Sample text input"
                                             Text="Sample text"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <Button Content="Primary Action"
                                                Style="{StaticResource EDAI.Button.Primary}"
                                                Margin="0,0,8,8"/>
                                        <Button Content="Secondary"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Margin="0,0,0,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </TabItem>

                <!-- ── Script Editor preview tab ────────────────────────────── -->
                <TabItem Header="Script Editor">
                    <Border BorderThickness="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                            CornerRadius="0,4,4,4" ClipToBounds="True">
                        <avalonEdit:TextEditor x:Name="CodePreviewEditor"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="13"
                                               ShowLineNumbers="True"
                                               IsReadOnly="True"
                                               WordWrap="False"
                                               Background="{DynamicResource MaterialDesign.Brush.Background}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                    </Border>
                </TabItem>

            </TabControl>
        </DockPanel>
    </Grid>
</Window>
