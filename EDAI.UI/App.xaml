<Application x:Class="EDAI.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:converters="clr-namespace:EDAI.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Orange"
                                             SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

            <!--
                Mutable brushes for form control border theming.
                Colors are updated at runtime by ApplyAppearance; initial values
                approximate the MDIX dark-theme defaults so the UI looks correct
                before the user has set a custom color.
            -->
            <SolidColorBrush x:Key="EDAI.Brush.ControlBorder"      Color="#616161" />
            <SolidColorBrush x:Key="EDAI.Brush.ControlHover"       Color="#909090" />
            <!--
                Button color brushes — always kept set so DynamicResource bindings in
                EDAI.Button.Primary never resolve to nothing. ApplyAppearance updates
                these with the user's chosen values (or falls back to the accent color).
            -->
            <SolidColorBrush x:Key="EDAI.Brush.ButtonBackground"   Color="#FF6D00" />
            <SolidColorBrush x:Key="EDAI.Brush.ButtonForeground"   Color="#FFFFFF" />

            <!--
                Named form-control styles derived from MDIX outlined styles.
                Setting BorderBrush here gives the user's Control Border / Hover
                theme colours a way into controls that already carry an explicit
                Style="{StaticResource MaterialDesign…}" attribute.
                Toolbar controls keep their own explicit styles and are not affected.
            -->
            <Style x:Key="EDAI.Form.TextBox" TargetType="{x:Type TextBox}"
                   BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="BorderBrush" Value="{DynamicResource EDAI.Brush.ControlBorder}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource EDAI.Brush.ControlHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="EDAI.Form.ComboBox" TargetType="{x:Type ComboBox}"
                   BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="BorderBrush" Value="{DynamicResource EDAI.Brush.ControlBorder}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource EDAI.Brush.ControlHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--
                EDAI.Form.CheckBox
                Custom ControlTemplate so the checkbox square uses DynamicResource brush
                references that respond to our theme color settings.
                MDIX resolves MaterialDesign.Brush.CheckBox.UncheckedBorder as a
                StaticResource in BAML scope — overriding Application.Resources or
                mutating the merged-dict brush cannot reach it reliably.
                This template bypasses MDIX entirely for the checkbox square visuals
                while keeping all other MaterialDesignCheckBox style setters via BasedOn.
            -->
            <Style x:Key="EDAI.Form.CheckBox" TargetType="{x:Type CheckBox}"
                   BasedOn="{StaticResource MaterialDesignCheckBox}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <BulletDecorator Background="Transparent" SnapsToDevicePixels="True">
                                <BulletDecorator.Bullet>
                                    <Border x:Name="CheckBorder"
                                            Width="18" Height="18"
                                            CornerRadius="2"
                                            BorderThickness="2"
                                            BorderBrush="{DynamicResource EDAI.Brush.ControlBorder}"
                                            Background="Transparent">
                                        <Path x:Name="CheckMark"
                                              Data="M 1,4 L 4,8 L 9,1"
                                              Stroke="White"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Uniform"
                                              Margin="2"
                                              Visibility="Collapsed"/>
                                    </Border>
                                </BulletDecorator.Bullet>
                                <ContentPresenter Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  RecognizesAccessKey="True"/>
                            </BulletDecorator>
                            <ControlTemplate.Triggers>
                                <!-- Checked: fill with primary color, show tick -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBorder" Property="Background"
                                            Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <Setter TargetName="CheckBorder" Property="BorderBrush"
                                            Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <!-- Hover unchecked: highlight border -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsChecked" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="CheckBorder" Property="BorderBrush"
                                            Value="{DynamicResource EDAI.Brush.ControlHover}"/>
                                </MultiTrigger>
                                <!-- Hover checked: lighten the fill -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsChecked" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="CheckBorder" Property="Background"
                                            Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                                    <Setter TargetName="CheckBorder" Property="BorderBrush"
                                            Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                                </MultiTrigger>
                                <!-- Disabled: reduce opacity -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.38"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--
                ToolbarComboBoxStyle
                Use this on any ComboBox that lives inside a ToolBar/ToolBarTray.
                The control itself is transparent with toolbar-coloured text/border.
                The popup dropdown uses the app background/foreground so it is always
                legible, and is outlined with the toolbar background colour so it is
                clearly visible when it opens.
            -->
            <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Foreground"     Value="{DynamicResource EDAI.Brush.ToolbarForeground}"/>
                <Setter Property="Background"     Value="Transparent"/>
                <Setter Property="BorderBrush"    Value="{DynamicResource EDAI.Brush.ToolbarForeground}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"        Value="6,3,0,3"/>
                <Setter Property="MaxDropDownHeight" Value="300"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <!-- Items in the popup use app colours, not toolbar colours -->
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Background}"/>
                            <Setter Property="Padding"    Value="10,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <!--
                                    Border is a direct Grid child so it always spans the full
                                    declared Width of the ComboBox, regardless of how the
                                    ToolBar sizes the ToggleButton inside it.
                                -->
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                        </Grid.ColumnDefinitions>
                                        <Path x:Name="Arrow"
                                              Grid.Column="1"
                                              Data="M 2,5 L 6,9 L 10,5"
                                              Stroke="{TemplateBinding Foreground}"
                                              StrokeThickness="1.5"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!--
                                    Transparent click-catcher. OverridesDefaultStyle="True"
                                    prevents the ToolBar's implicit ToggleButton style from
                                    constraining the button to auto/icon size, so
                                    HorizontalAlignment="Stretch" can fill the full border.
                                -->
                                <ToggleButton x:Name="ToggleButton"
                                              OverridesDefaultStyle="True"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Focusable="False"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsDropDownOpen,
                                                          RelativeSource={RelativeSource TemplatedParent},
                                                          Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- Selected value (visible when an item is selected) -->
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="7,0,24,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>

                                <!-- Hint text (visible when no item is selected) -->
                                <TextBlock x:Name="HintText"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"
                                           Text="{Binding Path=(materialDesign:HintAssist.Hint),
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Opacity="0.55"
                                           Margin="7,0,24,0"
                                           VerticalAlignment="Center"/>

                                <!-- Dropdown popup with app background and toolbar-coloured outline -->
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       Focusable="False"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                    <Border x:Name="DropDownBorder"
                                            MinWidth="{Binding ActualWidth,
                                                       RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Background="{DynamicResource MaterialDesign.Brush.Background}"
                                            BorderBrush="{DynamicResource EDAI.Brush.ToolbarBackground}"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Direction="270" ShadowDepth="3"
                                                              BlurRadius="8" Opacity="0.4" Color="Black"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter KeyboardNavigation.TabNavigation="Contained"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <!-- Arrow flips when the dropdown is open -->
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="Arrow" Property="Data" Value="M 2,9 L 6,5 L 10,9"/>
                                </Trigger>
                                <!-- Subtle hover feedback on the border -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <!-- Show hint when no item is selected -->
                                <Trigger Property="SelectedItem" Value="{x:Null}">
                                    <Setter TargetName="HintText"    Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!--
                EDAI.Button.Primary — raised button that respects the user's
                Button Color and Button Text theme settings.
                Use this everywhere MaterialDesignRaisedButton was used so that
                the two theme controls actually take effect.
            -->
            <Style x:Key="EDAI.Button.Primary" TargetType="{x:Type Button}"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{DynamicResource EDAI.Brush.ButtonBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource EDAI.Brush.ButtonForeground}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
