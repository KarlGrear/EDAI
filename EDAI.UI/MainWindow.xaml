<Window x:Class="EDAI.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:vm="clr-namespace:EDAI.UI.ViewModels"
        Title="Elite Dangerous AI"
        MinWidth="700" MinHeight="400"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>
        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource EDAI.Brush.ToolbarBackground}">
            <ToolBar Style="{DynamicResource MaterialDesignToolBar}" ClipToBounds="False"
                     Background="{DynamicResource EDAI.Brush.ToolbarBackground}">
                <TextBlock Text="ELITE DANGEROUS AI"
                           FontWeight="Bold" FontSize="13"
                           VerticalAlignment="Center" Margin="4,0,16,0"
                           Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}" />
                <Separator />
                <Button Command="{Binding NavigateToSettingsCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="Application Settings"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="Cog" />
                </Button>
                <Button Command="{Binding NavigateToEventConfigurationsCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="Event Configurations"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="ListBox" />
                </Button>
                <Button Command="{Binding NavigateToTestCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="Test"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="TestTube" />
                </Button>
                <Separator />
                <ToggleButton IsChecked="{Binding IsAlwaysOnTop}"
                              Command="{Binding ToggleAlwaysOnTopCommand}"
                              Style="{StaticResource MaterialDesignFlatToggleButton}"
                              ToolTip="Always On Top"
                              Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="Pin" />
                </ToggleButton>
                <ToggleButton IsChecked="{Binding IsTtsEnabled}"
                              Command="{Binding ToggleTtsCommand}"
                              Style="{StaticResource MaterialDesignFlatToggleButton}"
                              ToolTip="TTS On/Off"
                              Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="VolumeHigh" />
                </ToggleButton>
                <Button Command="{Binding NavigateToThemeCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="Customize Theme Colors"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="Palette" />
                </Button>
                <Separator />
                <Button Command="{Binding ClearResponsesCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="Clear Responses"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="DeleteSweep" />
                </Button>
                <Button Command="{Binding ShowAboutCommand}"
                        Style="{StaticResource MaterialDesignToolButton}"
                        ToolTip="About Elite Dangerous AI"
                        Foreground="{DynamicResource EDAI.Brush.ToolbarForeground}">
                    <materialDesign:PackIcon Kind="InformationOutline" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Dark.Foreground}"
                           FontSize="11" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ErrorMessage}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                           Foreground="#FFEE3333"
                           FontSize="11" FontStyle="Italic" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Responses + History tabs -->
            <TabControl Grid.Column="0" Margin="8,8,0,8"
                        Style="{StaticResource MaterialDesignTabControl}">

                <!-- ── AI Responses ─────────────────────────────── -->
                <TabItem Header="AI Responses">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Responses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ResponseDisplayItem}">
                                    <materialDesign:Card Margin="0,0,0,8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ConfigTitle}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                       Margin="0,0,0,4"
                                                       Visibility="{Binding ShowTitle, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                       FontSize="10" Opacity="0.5"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- ── History ──────────────────────────────────── -->
                <TabItem Header="History">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:HistoryItem}">
                                    <Expander IsExpanded="{Binding IsExpanded}"
                                              HorizontalContentAlignment="Stretch"
                                              Margin="0,0,0,4">
                                        <Expander.Header>
                                            <Grid Margin="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampDisplay}"
                                                           FontSize="10" Opacity="0.6"
                                                           VerticalAlignment="Top"
                                                           Margin="0,2,10,0"
                                                           FontFamily="Consolas" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding ConfigTitle}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               FontSize="11" Opacity="0.75"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Expander.Header>

                                        <!-- Expanded detail -->
                                        <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                                                CornerRadius="4" Padding="12" Margin="0,4,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Prompt"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                           Margin="0,0,0,4" />
                                                <TextBox Text="{Binding PromptSent, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         MaxHeight="180"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Margin="0,0,0,12" />
                                                <TextBlock Text="AI Response"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                           Margin="0,0,0,4" />
                                                <TextBox Text="{Binding RawAiResponse, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         MaxHeight="120"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="Transparent"
                                                         BorderThickness="0" />
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}" />

            <!-- Event log -->
            <DockPanel Grid.Column="2" Margin="4,8,8,8">
                <TextBlock DockPanel.Dock="Top"
                           Text="Event Log"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Margin="0,0,0,4" />
                <ListView ItemsSource="{Binding EventLog}"
                          FontSize="11"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:EventLogItem}">
                            <StackPanel>
                                <TextBlock Text="{Binding EventType}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TimestampDisplay}" Opacity="0.6" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
